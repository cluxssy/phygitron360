# =============================================================================
# Phygitron 360 — Environment Configuration
# =============================================================================
# 1. Copy this file to backend/.env
#    cp .env.example backend/.env
# 2. Fill in your values below
# 3. Run the setup script:
#    chmod +x scripts/setup.sh && ./scripts/setup.sh
# =============================================================================


# --- PostgreSQL Database ---
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=


# --- L1 Superadmin Seed Credentials ---
# This account is automatically created during setup.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=


# --- Security ---
SECRET_KEY=change_this_to_a_long_random_secret_string_in_production


# --- SMTP Email (Optional — leave blank to use mock/log mode) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=


# --- AI / LLM Keys (Optional — only needed for AI modules) ---
# Primary provider for single resume uploads, scoring, offer letters, assessments
# Options: gemini | groq | openai | mock
AI_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=
GROQ_RPM_LIMIT=3

# --- Bulk Upload Worker Settings ---
# Provider used specifically for bulk resume AI parsing (defaults to AI_PROVIDER if not set)
# Groq is recommended: free, 14,400 req/day, 8 parallel workers = handles 3000 resumes fast
# Options: groq | gemini | openai | mock
BULK_AI_PROVIDER=
# Number of parallel AI parse workers for bulk uploads (recommended: 4-8)
BULK_PARSE_WORKERS=8

APP_BASE_URL=http://localhost:5173