# =============================================================================
# Phygitron 360 — Environment Configuration
# =============================================================================
# 1. Copy this file to backend/.env
#    cp .env.example backend/.env
# 2. Fill in your values below
# 3. Run the setup script:
#    chmod +x scripts/setup.sh && ./scripts/setup.sh
# =============================================================================


# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phygitron360
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here


# --- L1 Superadmin Seed Credentials ---
# This account is automatically created during setup.
SUPERADMIN_EMAIL=superadmin@phygitron.com
SUPERADMIN_PASSWORD=ChangeMe@1234


# --- Security ---
SECRET_KEY=change_this_to_a_long_random_secret_string_in_production


# --- SMTP Email (Optional — leave blank to use mock/log mode) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDER_NAME="EWANDZ Digital HR"
COMPANY_NAME="EWANDZ Digital"


# --- AI / LLM Keys (Optional — only needed for AI modules) ---
AI_PROVIDER=mock
BULK_AI_PROVIDER=groq
BULK_PARSE_WORKERS=2

GOOGLE_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Application Setup ---
APP_BASE_URL=http://localhost:5173